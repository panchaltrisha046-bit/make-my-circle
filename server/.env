PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/makemycircle

# JWT Secret (IMPORTANT: Change this to a strong random string in production!)
JWT_SECRET=makemycircle_jwt_secret_key_please_change_in_production_to_something_random_and_secure

# Circle AI Configuration
# IMPORTANT: You MUST set ONE of the following AI providers to use AI Chat features:

# Option 1: OpenAI (Recommended - GPT-4o-mini)
# Get your API key from: https://platform.openai.com/api-keys
# Format: sk-proj-... or sk-...
# Then uncomment the line below and paste your actual key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Option 2: Google Gemini (Alternative)
# Get your API key from: https://makersuite.google.com/app/apikey
# Format: AIza...
# Then uncomment the lines below and paste your actual key
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-pro